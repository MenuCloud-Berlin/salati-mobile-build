auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
node-linker=isolated
# Kurzer virtueller Store-Pfad ausserhalb des Projekt-Trees: pnpms Standard-
# Verschachtelung (node_modules/.pnpm/<pkg>@<version>_<hash>/node_modules/<pkg>/...)
# kombiniert mit dem Repo-Pfad ueberschreitet Windows' 260-Zeichen-MAX_PATH fuer
# tief verschachtelte codegen-Dateien (z.B. react-native-async-storage
# ComponentDescriptors.cpp) - ninja.exe (Android-SDK-cmake-Bundle) hat dafuer
# KEINE Long-Path-Unterstuetzung, unabhaengig von Windows' LongPathsEnabled.
#
# BEWUSST ein RELATIVER Pfad, kein "C:/...": ein absoluter Windows-Pfad
# materialisiert auf dem EAS-iOS-Build-Worker (macOS) woertlich als Ordner
# namens "C:" - der Doppelpunkt darin bricht Xcodes Makefile-basierte
# Dependency-Dateien ("unexpected character in prerequisites").
#
# "../.pnpm-store" (1 Ebene hoch) war IMMER NOCH zu lang (268 statt <260
# Zeichen fuer react-native-async-storages ComponentDescriptors.cpp,
# reproduzierbar gescheitert) - 2 Ebenen hoch bis ins User-Home + ein
# 1-Zeichen-Ordnername schaffen genug Marge auf beiden Plattformen:
# Windows C:/Users/<user>/.v (~18 Zeichen), macOS /Users/expo/.v
# (~14 Zeichen, EAS-Workingdir liegt 2 Ebenen unter dem User-Home).
virtual-store-dir=../../.v
